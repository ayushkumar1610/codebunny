# ── ClickUp Configuration ────────────────────────────────────────────────────
CLICKUP_API_TOKEN=pk_your_clickup_api_token_here
CLICKUP_TEAM_ID=your_team_id_here
CLICKUP_WEBHOOK_SECRET=your_webhook_secret_here   # Used to verify incoming payloads

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://bunny:password@localhost:5432/codebunny_stats

# ── Webhook Server ────────────────────────────────────────────────────────────
PORT=3000
WEBHOOK_PATH=/webhooks/clickup                    # Endpoint ClickUp will POST to
PUBLIC_URL=https://your-server-url.com            # Required when registering webhook

# ── Git Configuration ─────────────────────────────────────────────────────────
REPOS_BASE_DIR=./repos                            # Local directory to clone repos into
GIT_DEFAULT_BRANCH=main                           # Base branch for new feature branches
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com

# ── GitHub / GitLab ───────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_token_here           # For private repos & PR creation
GITLAB_TOKEN=glpat_your_gitlab_token_here         # For GitLab repos & MR creation
GITHUB_DEFAULT_OWNER=your-github-org-or-username  # Default repo owner if not in task

# ── Agent Configuration ──────────────────────────────────────────────────────
AGENT_CLI=opencode                                # Which agent CLI to use? (opencode, claude, gemini)

# ── OpenCode CLI ──────────────────────────────────────────────────────────────
OPENCODE_PATH=opencode                            # Path to opencode binary (or just "opencode" if in PATH)
OPENCODE_MODEL=anthropic/claude-sonnet-4-5        # Model to use
OPENCODE_MAX_TOKENS=8192

# ── Agent Behaviour ───────────────────────────────────────────────────────────
# Comma-separated ClickUp custom field names that hold the repo URL
REPO_URL_FIELD_NAMES=repo_url,repository,git_url,github_url
# Branch prefix strategy: "task-id" | "task-name" | "both"
BRANCH_PREFIX_STRATEGY=both
# Whether to auto-push the branch and open a draft PR after OpenCode finishes
AUTO_CREATE_PR=true
OPENCODE_CONFIG=src/config/opencode.json